GERRIT_DIR=/var/gerrit
GERRIT_URL=https://review.spdk.io
OUTPUT_DIR=/output
LOG_LEVEL=INFO

FORWARDER_GITHUB_TOKEN=your_github_token_here
FORWARDER_GITHUB_REPO_URL=https://api.github.com/repos/spdk/spdk-ci
FORWARDER_TEST_MODE=false
FORWARDER_QUEUE_PROCESS_INTERVAL=60
FORWARDER_MAX_RUNNING_WORKFLOWS=3
FORWARDER_RECOVERY_WINDOW_DAYS=7
FORWARDER_GERRIT_QUERY_LIMIT=300
