GERRIT_DIR=/var/gerrit
CANONICAL_WEB_URL=https://review.spdk.io
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_URL=https://api.github.com/repos/spdk/spdk-ci
GERRIT_URL=https://review.spdk.io
GERRIT_BASE_URL=https://review.spdk.io
TEST_MODE=false
